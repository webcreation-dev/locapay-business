#!/usr/bin/expect -f
set timeout -1
spawn scp -o StrictHostKeyChecking=no scratch/count_script.js root@213.136.81.100:/root/count_script.js
expect "password:"
send "DQfhFtvXfr2iXLV28mzQ\r"
expect eof

spawn ssh -o StrictHostKeyChecking=no root@213.136.81.100 "node count_script.js"
expect "password:"
send "DQfhFtvXfr2iXLV28mzQ\r"
expect eof
